{
  "name": "Turbo",
  "version": "2.2.1",
  "description": "",
  "type": "module",
  "main": "index.js",
  "license": "ISC",
  "scripts": {
    "build": "npm run clean && webpack --config webpack.config.js --mode production",
    "dev": "node scripts/dev.js",
    "webpack:serve": "webpack serve --config webpack.config.js --mode development",
    "build:dev": "webpack --config webpack.config.js --mode development --watch",
    "clean": "rm -rf dist && rm -rf dist_sections",
    "start": "node server.js",
    "start:static": "npx serve dist",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"theme/**/*.{js,jsx,json,css,md}\"",
    "prepare": "husky install",
    "audit:ci": "npm audit --omit=dev --audit-level=high",
    "husky": "npm install husky --save-dev && husky install && npx husky add .husky/pre-commit 'npm run lint && npm run format'"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm run format"
    }
  },
  "fdk_feature": {
    "enable_section_chunking": true
  },
