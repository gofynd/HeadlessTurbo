# API/proxy configuration
PROXY_TARGET=https://api.fynd.com
DOMAIN=api.fynd.com
PORT=8080

# APPLICATION_TOKEN MUST be PUBLIC-SCOPE ONLY.
# It is injected into the storefront HTML and is readable by every visitor,
# every browser extension, and every third-party script on the page.
# Never put a partner-level or privileged token here.
APPLICATION_ID=your_application_id
APPLICATION_TOKEN=your_public_application_token

TURBO_DEV_PORT=5002
USE_PROXY=true
